// StudyHub – multi-user schema (Auth.js core + app models). Postgres (lokal Homebrew, prod Supabase).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Supabase: gepoolte Verbindung (Supavisor/pgbouncer, Port 6543) für die App (serverless-tauglich).
  url       = env("DATABASE_URL")
  // Direkte Verbindung (Port 5432) für Migrationen — pgbouncer kann kein DDL/Prepared Statements.
  directUrl = env("DIRECT_URL")
}

// ---------------- Auth.js core ----------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // app-specific
  passwordHash     String? // null for OAuth-only users
  role             String  @default("user") // "user" | "owner"
  plan             String  @default("free") // "free" | "owner" — bezahlter Zugang läuft über paidUntil
  paidUntil        DateTime? // Semester-Pass gültig bis (Einmalzahlung, kein Abo)
  stripeCustomerId String? @unique
  createdAt        DateTime @default(now())

  accounts      Account[]
  sessions      Session[]
  topicProgress TopicProgress[]
  srsCards      SrsCard[]
  examAttempts  ExamAttempt[]
  usage         Usage?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------- App progress ----------------
model TopicProgress {
  id            String   @id @default(cuid())
  userId        String
  topicId       String
  sectionsRead  String   @default("[]") // JSON string[]
  quizSeen      String   @default("[]")
  quizCorrect   String   @default("[]")
  exercisesDone String   @default("[]")
  lastSeen      DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId])
}

model SrsCard {
  id       String   @id @default(cuid())
  userId   String
  cardId   String
  reps     Int      @default(0)
  ease     Float    @default(2.5)
  interval Int      @default(0)
  due      DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId])
}

model ExamAttempt {
  id          String   @id @default(cuid())
  userId      String
  subjectId   String
  label       String
  date        DateTime @default(now())
  durationSec Int
  selfScore   Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Usage {
  userId         String   @id
  pagesOpened    String   @default("[]") // JSON: distinct topicId[]
  flashcardsRead Int      @default(0)
  exercisesDone  Int      @default(0)
  quizAnswered   Int      @default(0)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
