# ============================================================================
#  StudyHub – Konfiguration. Kopiere diese Datei zu ".env.local".
#  Pflicht: AUTH_SECRET, OWNER_EMAIL, DATABASE_URL + DIRECT_URL. Der Rest ist
#  optional (Features schalten sich frei, sobald die Keys gesetzt sind).
#  In Produktion (Vercel) werden ALLE diese Variablen im Projekt-Dashboard
#  hinterlegt — nicht in Dateien.
# ============================================================================

# --- Datenbank (PFLICHT) ---
# LOKAL (Homebrew-Postgres, einmalig: brew install postgresql@17 &&
#   brew services start postgresql@17 && /opt/homebrew/opt/postgresql@17/bin/createdb studyhub):
#   DATABASE_URL="postgresql://DEIN-MAC-USER@localhost:5432/studyhub"
#   DIRECT_URL  ="postgresql://DEIN-MAC-USER@localhost:5432/studyhub"
# PRODUKTION (Supabase → Project → Settings → Database → "Connection string"):
#   DATABASE_URL = "Transaction"-Pooler (Port 6543), Suffix ?pgbouncer=true
#   DIRECT_URL   = "Session"-Pooler (Port 5432) — nur für Migrationen
DATABASE_URL="postgresql://postgres.PROJEKTREF:PASSWORT@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJEKTREF:PASSWORT@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Login / Auth (PFLICHT) ---
# Secret generieren:  npx auth secret   (oder: openssl rand -base64 33)
AUTH_SECRET=
# Lokal: http://localhost:3000  ·  Produktion: https://DEIN-PROJEKT.vercel.app
AUTH_URL=http://localhost:3000
# Dieses Konto ist UNBEGRENZT (dein Demo-/Owner-Konto):
OWNER_EMAIL=deine@email.de

# --- Google-Login (optional) ---
# Google Cloud Console → APIs & Dienste → Anmeldedaten → OAuth-Client-ID (Webanwendung)
# Autorisierte Weiterleitungs-URI:  http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Bezahlung / Stripe (optional, Testmodus) ---
# https://dashboard.stripe.com (Testmodus) → API-Keys (sk_test_...)
# Produkt + EINMALIGEN Preis anlegen (Semester-Pass) → dessen price_... als STRIPE_PRICE_ID
# Lokaler Webhook:  stripe listen --forward-to localhost:3001/api/stripe/webhook
#   → das angezeigte whsec_... als STRIPE_WEBHOOK_SECRET eintragen
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Semesterende-Override (optional, sonst automatisch SoSe→30.09. / WiSe→31.03.):
# SEMESTER_END_OVERRIDE=2026-09-30

# --- Transaktions-Mails / Resend (optional; nötig für Passwort-Reset & Verifizierung) ---
# https://resend.com → API Keys; Domain verifizieren, sonst kein Versand möglich.
RESEND_API_KEY=re_...
MAIL_FROM="StudyHub <mail@deine-domain.de>"

# --- KI-Tutor (optional) ---
# https://console.anthropic.com → API Keys (Spend-Limit im Dashboard setzen!)
ANTHROPIC_API_KEY=sk-ant-...
# Modell (Standard = kleinstes/günstigstes). Stärker: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5
